generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String
  role            Role            @default(ARTIST)
  slug            String?         @unique
  studioName      String?
  state           String?
  city            String?
  instagram       String?
  whatsappMessage        String?         @default("Olá! Segue o orçamento da sua tatuagem:")
  requireReferenceImages Boolean         @default(false)
  createdAt              DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  requests        TattooRequest[]
  quotes          Quote[]
  appointments    Appointment[]
  availabilities  Availability[]
  availabilityBlocks AvailabilityBlock[]
  tattooStyles    TattooStyle[]
}

model TattooStyle {
  id        String   @id @default(cuid())
  name      String
  artistId  String
  artist    User     @relation(fields: [artistId], references: [id])
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([artistId, name])
}

enum Role {
  ARTIST
  CLIENT
}

model TattooRequest {
  id              String        @id @default(cuid())
  clientName      String
  clientEmail     String
  clientPhone     String
  placement       String
  size            String
  style           String
  description     String
  referenceImages String[]
  preferredDate   String
  preferredTime   String
  status          RequestStatus @default(PENDING)
  artistId        String
  artist          User          @relation(fields: [artistId], references: [id])
  quote           Quote?
  appointment     Appointment?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum RequestStatus {
  PENDING
  QUOTED
  APPROVED
  REJECTED
  SCHEDULED
  CANCELLED
}

model Quote {
  id            String        @id @default(cuid())
  requestId     String        @unique
  request       TattooRequest @relation(fields: [requestId], references: [id])
  artistId      String
  artist        User          @relation(fields: [artistId], references: [id])
  priceEstimate Float
  sessionTime   String
  message       String
  status        QuoteStatus   @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Appointment {
  id         String         @id @default(cuid())
  artistId   String
  artist     User           @relation(fields: [artistId], references: [id])
  requestId  String?        @unique
  request    TattooRequest? @relation(fields: [requestId], references: [id])
  clientName String?
  date       String
  startTime  String
  endTime    String
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Availability {
  id           String   @id @default(cuid())
  artistId     String
  artist       User     @relation(fields: [artistId], references: [id])
  dayOfWeek    Int      // 0=dom, 1=seg, ..., 6=sab
  startTime    String   // "09:00"
  endTime      String   // "18:00"
  lunchStart   String?
  lunchEnd     String?
  slotDuration Int      @default(60)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  artistId  String
  artist    User     @relation(fields: [artistId], references: [id])
  date      String
  startTime String?
  endTime   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
